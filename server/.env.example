GROQ_API_KEY=your_groq_api_key_here
NODE_ENV=development
PORT=5000
# Important: if password contains '@' or special chars, URL-encode it.
# Example password: 9104@332333 -> 9104%40332333
DATABASE_URL=postgresql://postgres:your_encoded_password@db.your-project.supabase.co:5432/postgres
SESSION_SECRET=replace_with_a_long_random_secret
DB_CONNECTION_TIMEOUT=5000
