# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/nyayasetu
DB_CONNECTION_TIMEOUT=5000

# Authentication
ADMIN_USERNAME=admin@nyayasetu.ai
ADMIN_PASSWORD=Admin@12345

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-this

# OAuth/Google Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URLs
FRONTEND_URL=http://localhost:5173
FRONTEND_PREVIEW_URL=
ALLOWED_ORIGINS=

# Groq API Configuration
GROQ_API_KEY=your-groq-api-key

# Razorpay Configuration
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_CURRENCY=INR
RAZORPAY_PROFESSIONAL_AMOUNT_PAISE=99900
RAZORPAY_ENTERPRISE_AMOUNT_PAISE=249900

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Document Encryption
# Generate a new key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOCUMENT_ENCRYPTION_KEY=your-32-byte-hex-encoded-key
